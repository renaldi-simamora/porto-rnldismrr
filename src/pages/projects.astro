---
import BaseLayout from '../Layouts/BaseLayout.astro'
import { projects } from '../constant'
---

<BaseLayout title="Projects - BuahKita & Budgetly">
  <main style="min-height:100vh; display:flex; align-items:center; justify-content:center; background:#04060d; color:#e8f2ff; padding:4rem 2rem;">
    <div style="max-width:1180px; width:100%;">
      <h1 style="font-family: 'Syne', sans-serif; font-size:28px; margin:0 0 22px;">Projects</h1>
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(340px,1fr)); gap:28px;">
        {projects.filter(p => p.title === 'BuahKita' || p.title === 'Budgetly DBS').map(p => (
          <article style="background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); border:1px solid rgba(255,255,255,0.04); border-radius:18px; overflow:hidden; display:flex; flex-direction:column; min-height:420px;">
            <div style="height:260px; background:#0a0a0a; position:relative;">
              <img src={p.image} alt={p.title} style="width:100%; height:100%; object-fit:cover; display:block;" />
            </div>
            <div style="padding:1.6rem 1.8rem; flex:1; display:flex; flex-direction:column; justify-content:space-between;">
              <div>
                <h3 style="margin:0 0 10px; font-family:'Syne', sans-serif; font-size:20px;">{p.title}</h3>
                <p style="margin:0 0 14px; color:rgba(170,195,230,0.6); line-height:1.7;">{p.description} {p.links[0] && <a href={p.links[0].url} target="_blank" rel="noopener noreferrer" style="color:#c8ff2a; text-decoration:underline;">Live</a>}</p>
              </div>
              <div>
                <a href={p.links[0]?.url ?? '#'} target="_blank" rel="noopener noreferrer" style="display:inline-block; color:#9bdc2a; text-decoration:none; font-family:'Space Mono', monospace; letter-spacing:2px;">VIEW PROJECT →</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>
