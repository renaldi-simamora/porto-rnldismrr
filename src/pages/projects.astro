---
import BaseLayout from '../Layouts/BaseLayout.astro'
import { projects } from '../constant'
---

<BaseLayout title="Projects - Portfolio">
  <main style="min-height:100vh; display:flex; align-items:center; justify-content:center; background:#04060d; color:#e8f2ff; padding:4rem 2rem;">
    <div style="max-width:1180px; width:100%;">
      <h1 style="font-family: 'Syne', sans-serif; font-size:28px; margin:0 0 22px;">Projects</h1>
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(320px,1fr)); gap:28px;">
        {projects.map((p, index) => (
          <article style="background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01)); border:1px solid rgba(255,255,255,0.06); border-radius:18px; overflow:hidden; display:flex; flex-direction:column; min-height:440px;">
            <div style="height:250px; background:#0a0a0a; position:relative;">
              <img src={p.image} alt={p.title} style="width:100%; height:100%; object-fit:cover; display:block;" />
              <div style="position:absolute; top:14px; right:16px; font-family:'Space Mono', monospace; font-size:11px; color:#c8ff2a; letter-spacing:2px;">{String(index + 1).padStart(2, '0')}</div>
            </div>
            <div style="padding:1.6rem 1.8rem; flex:1; display:flex; flex-direction:column; gap:14px;">
              <div>
                <h3 style="margin:0 0 10px; font-family:'Syne', sans-serif; font-size:20px;">{p.title}</h3>
                <p style="margin:0; color:rgba(170,195,230,0.72); line-height:1.7;">{p.description}</p>
              </div>
              <details style="padding:12px 14px; border-radius:14px; background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.06);">
                <summary style="cursor:pointer; color:#c8ff2a; font-family:'Space Mono', monospace; letter-spacing:2px; font-size:12px; list-style:none;">Lihat keterangan</summary>
                <div style="display:grid; gap:10px; margin-top:12px; color:rgba(232,242,255,0.82); line-height:1.7; font-size:14px;">
                  {p.details?.map(detail => (
                    <div>
                      <strong style="display:block; color:#9bdc2a; font-size:12px; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:4px;">{detail.label}</strong>
                      <span>{detail.text}</span>
                    </div>
                  ))}
                  {('qaImage' in p && p.qaImage) && (
                    <div style="margin-top:8px; border-top:1px solid rgba(255,255,255,0.06); padding-top:12px;">
                      <strong style="display:block; color:#9bdc2a; font-size:12px; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:8px;">QA Testing Summary</strong>
                      <div style="border-radius:8px; overflow:hidden; background:rgba(0,0,0,0.2);">
                        <a href={p.qaImage} target="_blank" rel="noopener noreferrer">
                          <img src={p.qaImage} alt="QA Testing Summary" style="width:100%; height:auto; display:block;" />
                        </a>
                      </div>
                    </div>
                  )}
                </div>
              </details>
              <div style="display:flex; flex-wrap:wrap; gap:8px;">
                {p.technologies?.map(tech => (
                  <span style="padding:6px 10px; border-radius:999px; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.06); font-size:10px; color:rgba(240,244,248,0.8); font-family:'Space Mono', monospace; letter-spacing:.8px;">{tech}</span>
                ))}
              </div>
              <div style="margin-top:auto; display:flex; gap:12px; flex-wrap:wrap;">
                {p.links.map(link => (
                  <a href={link.url} target="_blank" rel="noopener noreferrer" style="display:inline-block; padding:10px 14px; border-radius:999px; color:#c8ff2a; text-decoration:none; font-family:'Space Mono', monospace; letter-spacing:2px; border:1px solid rgba(200,255,42,0.2); background:rgba(200,255,42,0.08);">{link.text}</a>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>
